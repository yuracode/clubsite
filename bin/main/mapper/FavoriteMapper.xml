<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.clubsite.mapper.FavoriteMapper">
    <resultMap id="FavoriteResultMap" type="com.example.clubsite.model.Favorite">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="targetId" column="target_id"/>
        <association property="target" javaType="com.example.clubsite.model.User">
            <id property="id" column="t_id"/>
            <result property="nickname" column="t_nickname"/>
            <result property="profileImage" column="t_profile_image"/>
        </association>
    </resultMap>

    <select id="findByUserId" resultMap="FavoriteResultMap">
        SELECT f.*, u.id AS t_id, u.nickname AS t_nickname, u.profile_image AS t_profile_image
        FROM favorites f
        JOIN users u ON f.target_id = u.id
        WHERE f.user_id = #{userId}
    </select>

    <select id="exists" resultType="boolean">
        SELECT COUNT(*) > 0 FROM favorites WHERE user_id = #{userId} AND target_id = #{targetId}
    </select>

    <insert id="insert">
        INSERT INTO favorites (user_id, target_id) VALUES (#{userId}, #{targetId})
    </insert>

    <delete id="delete">
        DELETE FROM favorites WHERE user_id = #{userId} AND target_id = #{targetId}
    </delete>
</mapper>
